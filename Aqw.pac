function FindProxyForURL(url, host) {
  // إذا كان العنوان IP للعميل ضمن شبكة داخلية معينة، لا تستخدم الوكيل
  if (isInNet(myIpAddress(), "192.168.1.0", "255.255.255.0")) {
    return "DIRECT"; // اتصال مباشر للشبكات المحلية
  }

  // توجيه كل حركة المرور الأخرى عبر وكيل SOCKS5 على المنفذ 1080
  // (تأكد من أن هذا الوكيل يدعم التشفير أو يحمي البيانات)
  return "SOCKS5 127.0.0.1:1080; SOCKS 127.0.0.1:1080";
}
